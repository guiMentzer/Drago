<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="Drago">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import Drago urdf file -->
    <xacro:include filename="$(find drago_pkg)/urdf/drago.urdf" />

    <!-- Import control_xacro -->
    <xacro:include filename="Drago.ros2_control.xacro" />


    <xacro:Drago_ros2_control name="DragoSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
